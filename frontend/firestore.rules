rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function hasMapping() {
      return signedIn()
        && exists(/databases/$(database)/documents/auth_mappings/$(request.auth.uid));
    }

    function mappedTelegramId() {
      return get(/databases/$(database)/documents/auth_mappings/$(request.auth.uid)).data.telegramId;
    }

    function isAdmin() {
      return hasMapping()
        && exists(/databases/$(database)/documents/users/$(mappedTelegramId()))
        && get(/databases/$(database)/documents/users/$(mappedTelegramId())).data.role == 'admin';
    }

    // Auth mappings - maps firebaseUid to telegramId for security rules
    match /auth_mappings/{firebaseUid} {
      allow read, write: if signedIn() && request.auth.uid == firebaseUid;
    }

    // Users collection - document ID is telegramId
    match /users/{telegramId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && (
        (hasMapping() && mappedTelegramId() == telegramId)
        || isAdmin()
      );
    }

    // Unlockables - public read, admin write only
    match /unlockables/{unlockableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User unlockables - allow authenticated users
    match /user_unlockables/{docId} {
      allow read, write: if signedIn();
    }

    // User favorites - allow authenticated users
    match /user_favorites/{docId} {
      allow read, write: if signedIn();
    }

    // Settings - admin write, authenticated read
    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}