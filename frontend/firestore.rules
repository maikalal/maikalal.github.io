rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - allow authenticated access
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Unlockables - public read, admin write only
    match /unlockables/{unlockableId} {
      allow read: if true;
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // User unlockables - allow authenticated users
    match /user_unlockables/{docId} {
      allow read, write: if request.auth != null;
    }
    
    // User favorites - allow authenticated users
    match /user_favorites/{docId} {
      allow read, write: if request.auth != null;
    }
    
    // Settings - admin write, authenticated read
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}