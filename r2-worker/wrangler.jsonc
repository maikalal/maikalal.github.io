{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "r2-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-17",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "unlockables-bucket"
		}
	]
}